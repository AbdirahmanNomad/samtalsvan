# ================================================
# Samtalsvan Environment Configuration
# ================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ================================================

# ================================================
# REQUIRED - Application Settings
# ================================================
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# ================================================
# CORS Configuration
# ================================================
# Comma-separated list of allowed origins, or * for any
CORS_ORIGIN=*

# ================================================
# Rate Limiting (requests per minute)
# ================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_CREATE_CALL_MAX=10
RATE_LIMIT_CONTACT_MAX=20
RATE_LIMIT_GDPR_MAX=5

# ================================================
# Security Secrets (generate for production)
# ================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=
JWT_SECRET=

# ================================================
# ICE/TURN Server Configuration (for NAT traversal)
# ================================================

# Option 1: OpenRelay (Free 50GB/month)
# Sign up at https://www.metered.ca/tools/openrelay/
# OPENRELAY_ENABLED=true
# OPENRELAY_API_KEY=your-openrelay-api-key

# Option 2: Custom TURN servers
# Format: turn:server:port|username|credential (comma-separated)
# TURN_SERVERS=turn:turn.example.com:3478|myuser|mypass
# TURN_USERNAME=fallback-username
# TURN_CREDENTIAL=fallback-credential
